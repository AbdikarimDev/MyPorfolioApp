{
  "expo": {
    "name": "abdikarimPorfolio",
    "slug": "abdikarimPorfolio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "@/assets/svg.png",
    "scheme": "abdikarimporfolio",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "@/assets/svg.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "@/assets/svg.png",
        "backgroundImage": "@/assets/svg.png",
        "monochromeImage": "@/assets/svg.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "@/assets/svg.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "@/assets/svg.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
